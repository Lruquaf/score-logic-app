# Core application
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/scorelogic
AUTH_SECRET=replace-with-a-long-random-secret

# Optional self-hosted auth settings
AUTH_URL=http://127.0.0.1:3007
AUTH_TRUST_HOST=true
DAILY_TIME_ZONE=Europe/Istanbul

# Optional OAuth / email providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=
AUTH_RESEND_FROM=ScoreLogic <noreply@example.com>

# Optional distributed cache / rate limiting via Upstash REST
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
