{
  "name": "scorelogic-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1 --port 3007",
    "local:up": "node scripts/local-up.mjs",
    "local:down": "node scripts/local-down.mjs",
    "local:status": "node scripts/local-status.mjs",
    "prebuild": "node scripts/guard-build.mjs",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "next start",
    "start:local": "next start --hostname 127.0.0.1 --port 3007",
    "start:standalone": "node scripts/start-standalone.mjs",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:setup": "node scripts/db-setup.mjs",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.20.0",
    "@tanstack/react-query": "^5.59.0",
    "@upstash/ratelimit": "^2.0.4",
    "@upstash/redis": "^1.34.3",
    "framer-motion": "^11.11.11",
    "jose": "^5.9.3",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.3.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.20.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
